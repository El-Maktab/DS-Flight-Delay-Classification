# Copy this file to .env and fill in your values
# .env is git-ignored; .env.example is committed as a template

# Weather API (Open-Meteo is free and key-less; add key here if using another provider)
WEATHER_API_KEY=

# MLflow tracking server (leave empty to use local ./mlruns)
MLFLOW_TRACKING_URI=

# Paths (override defaults if needed)
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
EXTERNAL_DATA_DIR=data/external
